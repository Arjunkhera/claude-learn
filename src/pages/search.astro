---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search">
  <div class="page">
    <div class="search-bar">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
      </svg>
      <input type="text" placeholder="Search features, workflows, concepts..." autofocus />
    </div>

    <div class="tabs">
      <button class="tab active">All</button>
      <button class="tab">Storybooks</button>
      <button class="tab">Cookbooks</button>
      <button class="tab">Glossary</button>
      <button class="tab">Changelog</button>
    </div>

    <div class="results-placeholder">
      <p>Search will be implemented in Phase 2.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.85rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    background: var(--color-surface);
    margin-bottom: 2rem;
  }

  .search-bar svg {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-bar input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 1.05rem;
    font-family: var(--font-sans);
    background: transparent;
    color: var(--color-text);
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .tab {
    padding: 0.6rem 1.25rem;
    border: none;
    background: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
  }

  .tab.active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    font-weight: 500;
  }

  .results-placeholder {
    text-align: center;
    padding: 4rem 0;
    color: var(--color-text-muted);
    font-size: 0.925rem;
  }
</style>
