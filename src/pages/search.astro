---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Search">
  <div class="page">
    <h1 class="sr-only">Search</h1>

    {/* Pillar filter tabs — toggled by JS, passed to Pagefind as a filter */}
    <div class="tabs" id="pillar-tabs" role="tablist" aria-label="Filter by pillar">
      <button class="tab active" data-pillar="" role="tab" aria-selected="true">All</button>
      <button class="tab" data-pillar="storybooks" role="tab" aria-selected="false">Storybooks</button>
      <button class="tab" data-pillar="cookbooks" role="tab" aria-selected="false">Cookbooks</button>
      <button class="tab" data-pillar="glossary" role="tab" aria-selected="false">Glossary</button>
      <button class="tab" data-pillar="changelog" role="tab" aria-selected="false">Changelog</button>
    </div>

    {/* Pagefind mounts its own input + results here */}
    <div id="search-container"></div>
  </div>
</BaseLayout>

{/*
  Load Pagefind UI assets.
  During `astro dev` the pagefind index doesn't exist yet (it's generated by `npm run build`),
  so we guard the import to avoid a console error in dev mode.
  In the built site, /pagefind/pagefind-ui.js is served from dist/pagefind/.
*/}
<script>
  import { PagefindUI } from '@pagefind/default-ui';

  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') ?? '';

  // Active pillar filter (empty string = All)
  let activePillar = '';

  // Initialise PagefindUI
  const ui = new PagefindUI({
    element: '#search-container',
    showSubResults: true,
    showImages: false,
    excerptLength: 30,
    highlightParam: 'highlight',
    defaultValue: initialQuery,
    // Filters are applied imperatively below via ui.triggerSearch()
  });

  // Trigger an initial search if there is a ?q= param
  if (initialQuery) {
    ui.triggerSearch(initialQuery);
  }

  // --- Pillar tab filtering ---
  const tabsEl = document.getElementById('pillar-tabs');
  tabsEl?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('button[data-pillar]') as HTMLButtonElement | null;
    if (!btn) return;

    // Update active state
    tabsEl.querySelectorAll('.tab').forEach((t) => {
      t.classList.remove('active');
      t.setAttribute('aria-selected', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-selected', 'true');

    activePillar = btn.dataset.pillar ?? '';

    // Re-run the current search with the new filter
    const currentInput = document.querySelector<HTMLInputElement>('#search-container input[type=text]');
    const query = currentInput?.value ?? '';
    if (activePillar) {
      ui.triggerSearch(query, { filters: { pillar: activePillar } });
    } else {
      ui.triggerSearch(query);
    }
  });

  // Sync URL ?q= as the user types (for shareability)
  document.getElementById('search-container')?.addEventListener('input', (e) => {
    const input = e.target as HTMLInputElement;
    if (input.tagName !== 'INPUT') return;
    const url = new URL(window.location.href);
    if (input.value) {
      url.searchParams.set('q', input.value);
    } else {
      url.searchParams.delete('q');
    }
    window.history.replaceState({}, '', url.toString());
  });
</script>

<style is:global>
  /*
    Override Pagefind's default CSS custom properties to match the site's design system.
    These MUST be :global because Pagefind injects its own shadow-DOM-free HTML into the page.
  */
  :root {
    --pagefind-ui-scale: 1;
    --pagefind-ui-primary: var(--color-accent);
    --pagefind-ui-text: var(--color-text);
    --pagefind-ui-background: var(--color-surface);
    --pagefind-ui-border: var(--color-border);
    --pagefind-ui-tag: var(--color-accent-light);
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: var(--radius-md);
    --pagefind-ui-image-border-radius: var(--radius-sm);
    --pagefind-ui-font: var(--font-sans);
  }

  /* Tighten the search input styling to match .search-bar on the rest of the site */
  .pagefind-ui__search-input {
    font-family: var(--font-sans) !important;
    font-size: 1.05rem !important;
    border-radius: var(--radius-lg) !important;
  }

  .pagefind-ui__search-clear {
    color: var(--color-text-muted) !important;
  }

  /* Result cards */
  .pagefind-ui__result {
    border-color: var(--color-border) !important;
    border-radius: var(--radius-md) !important;
    padding: 1.25rem !important;
    background: var(--color-surface) !important;
  }

  .pagefind-ui__result:hover {
    border-color: var(--color-accent) !important;
  }

  .pagefind-ui__result-title {
    font-size: 1rem !important;
    font-weight: 600 !important;
  }

  .pagefind-ui__result-excerpt {
    font-size: 0.9rem !important;
    color: var(--color-text-muted) !important;
  }

  mark {
    background: var(--color-accent-light) !important;
    color: var(--color-accent) !important;
    border-radius: 2px;
    padding: 0 2px;
  }

  /* "Load more" button */
  .pagefind-ui__button {
    background: var(--color-accent) !important;
    color: #fff !important;
    border-radius: var(--radius-md) !important;
    font-family: var(--font-sans) !important;
    font-weight: 500 !important;
  }

  .pagefind-ui__button:hover {
    opacity: 0.9;
  }
</style>

<style>
  .page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  /* Visually hidden heading for a11y */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .tabs {
    display: flex;
    gap: 0.25rem;
    border-bottom: 1px solid var(--color-border);
    margin-bottom: 2rem;
  }

  .tab {
    padding: 0.6rem 1.25rem;
    border: none;
    background: none;
    font-size: 0.9rem;
    font-family: var(--font-sans);
    color: var(--color-text-muted);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -1px;
    transition: color 0.12s, border-color 0.12s;
  }

  .tab:hover {
    color: var(--color-text);
  }

  .tab.active {
    color: var(--color-text);
    border-bottom-color: var(--color-accent);
    font-weight: 500;
  }

  #search-container {
    margin-top: 0;
  }
</style>
