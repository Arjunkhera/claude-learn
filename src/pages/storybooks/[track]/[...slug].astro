---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import TrackProgress from '../../../components/TrackProgress.astro';
import ChapterNav from '../../../components/ChapterNav.astro';
import CrossLinkCard from '../../../components/CrossLinkCard.astro';
import DifficultyBadge from '../../../components/DifficultyBadge.astro';
import FeaturePill from '../../../components/FeaturePill.astro';

export async function getStaticPaths() {
  const all = await getCollection('storybooks');
  return all.map((entry) => {
    // entry.id is like "101/01-overview" (no .md)
    const parts = entry.id.split('/');
    const track = parts[0] as '101' | '201' | '301' | '401';
    const slug = parts.slice(1).join('/');
    return {
      params: { track, slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { track } = Astro.params as { track: '101' | '201' | '301' | '401' };

const { Content } = await render(entry);

// Gather all chapters in this track for prev/next and progress
const allChapters = await getCollection('storybooks');
const trackChapters = allChapters
  .filter((c) => c.data.track === track)
  .sort((a, b) => a.data.chapter - b.data.chapter);

const currentIndex = trackChapters.findIndex((c) => c.id === entry.id);
const prevChapter = currentIndex > 0 ? trackChapters[currentIndex - 1] : null;
const nextChapter = currentIndex < trackChapters.length - 1 ? trackChapters[currentIndex + 1] : null;

function chapterHref(c: (typeof trackChapters)[0]) {
  const parts = c.id.split('/');
  const t = parts[0];
  const s = parts.slice(1).join('/');
  return `/storybooks/${t}/${s}`;
}

const trackNames: Record<string, string> = {
  '101': 'Starter',
  '201': 'Practitioner',
  '301': 'Builder',
  '401': 'Expert',
};

const trackName = trackNames[track] ?? track;
const hasXLinks = entry.data.cross_links && entry.data.cross_links.length > 0;
---

<BaseLayout title={entry.data.title} description={entry.data.description}>
  <div class="chapter-page">
    <div class="chapter-layout">
      <!-- Main column -->
      <article class="chapter-main">
        <!-- Breadcrumb -->
        <nav class="breadcrumb" aria-label="Breadcrumb">
          <a href="/storybooks">Storybooks</a>
          <span aria-hidden="true">›</span>
          <a href={`/storybooks/${track}`}>{track} {trackName}</a>
          <span aria-hidden="true">›</span>
          <span>Chapter {entry.data.chapter}: {entry.data.title}</span>
        </nav>

        <!-- Progress -->
        <TrackProgress
          current={entry.data.chapter}
          total={trackChapters.length || 1}
          track={track}
        />

        <!-- Header -->
        <header class="chapter-header">
          <div class="chapter-meta">
            <DifficultyBadge difficulty={entry.data.difficulty} track={track} />
            {entry.data.features_used.length > 0 && (
              <div class="feature-pills">
                {entry.data.features_used.map((f) => (
                  <FeaturePill name={f} href={`/glossary/${f}`} />
                ))}
              </div>
            )}
          </div>
          <h1 class="chapter-title">
            <span class="chapter-num">Chapter {entry.data.chapter}</span>
            {entry.data.title}
          </h1>
          {entry.data.description && (
            <p class="chapter-subtitle">{entry.data.description}</p>
          )}
        </header>

        <!-- Content -->
        <div class="chapter-content prose">
          <Content />
        </div>

        <!-- Mobile cross-links -->
        {hasXLinks && (
          <aside class="cross-links cross-links--mobile">
            <h3 class="cross-links-title">Related</h3>
            <div class="cross-links-list">
              {entry.data.cross_links.map((link) => (
                <CrossLinkCard
                  href={`/${link}`}
                  pillar={link.startsWith('storybooks/101') ? '101' : link.startsWith('storybooks/201') ? '201' : link.startsWith('storybooks/301') ? '301' : link.startsWith('storybooks/401') ? '401' : link.startsWith('cookbooks') ? 'cookbook' : 'glossary'}
                  title={link.split('/').pop()?.replace(/-/g, ' ') ?? link}
                  preview="Related resource"
                />
              ))}
            </div>
          </aside>
        )}

        <!-- Chapter navigation -->
        <ChapterNav
          prev={prevChapter ? { href: chapterHref(prevChapter), title: prevChapter.data.title } : undefined}
          next={nextChapter ? { href: chapterHref(nextChapter), title: nextChapter.data.title } : undefined}
        />
      </article>

      <!-- Sidebar cross-links (desktop) -->
      {hasXLinks && (
        <aside class="chapter-sidebar">
          <div class="sidebar-sticky">
            <h3 class="cross-links-title">Related</h3>
            <div class="cross-links-list">
              {entry.data.cross_links.map((link) => (
                <CrossLinkCard
                  href={`/${link}`}
                  pillar={link.startsWith('storybooks/101') ? '101' : link.startsWith('storybooks/201') ? '201' : link.startsWith('storybooks/301') ? '301' : link.startsWith('storybooks/401') ? '401' : link.startsWith('cookbooks') ? 'cookbook' : 'glossary'}
                  title={link.split('/').pop()?.replace(/-/g, ' ') ?? link}
                  preview="Related resource"
                />
              ))}
            </div>
          </div>
        </aside>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .chapter-page {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .chapter-layout {
    display: grid;
    grid-template-columns: 1fr 280px;
    gap: 3rem;
    align-items: start;
  }

  .chapter-main {
    min-width: 0;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .chapter-header {
    margin-bottom: 2.5rem;
  }

  .chapter-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .feature-pills {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .chapter-num {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-muted);
    margin-bottom: 0.35rem;
  }

  .chapter-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
    margin-bottom: 0.75rem;
  }

  .chapter-subtitle {
    font-size: 1.05rem;
    color: var(--color-text-muted);
    line-height: 1.65;
  }

  /* Prose content styles */
  .prose {
    max-width: var(--content-width);
    font-size: 1rem;
    line-height: 1.75;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
    color: var(--color-text);
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0 1.25rem 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1.5rem 0;
  }

  .prose :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  /* Sidebar */
  .chapter-sidebar {
    display: block;
  }

  .sidebar-sticky {
    position: sticky;
    top: calc(var(--nav-height) + 1.5rem);
  }

  .cross-links-title {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .cross-links-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Mobile cross-links shown only on small screens */
  .cross-links--mobile {
    display: none;
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  @media (max-width: 768px) {
    .chapter-layout {
      grid-template-columns: 1fr;
    }

    .chapter-sidebar {
      display: none;
    }

    .cross-links--mobile {
      display: block;
    }

    .chapter-title {
      font-size: 1.5rem;
    }
  }
</style>
