---
import BaseLayout from '../../layouts/BaseLayout.astro';

const categories = [
  { id: 'core', name: 'Core', count: 6, items: ['Overview', 'CLI', 'Context Window', 'Permissions', 'Memory', 'Settings'] },
  { id: 'extensions', name: 'Extensions', count: 6, items: ['Skills', 'Hooks', 'MCP', 'Subagents', 'Agent Teams', 'Plugins'] },
  { id: 'integrations', name: 'Integrations', count: 2, items: ['IDE Extensions', 'CI/CD'] },
  { id: 'concepts', name: 'Concepts', count: 3, items: ['Agentic Loop', 'Context Management', 'Permission Model'] },
  { id: 'guides', name: 'Guides', count: 5, items: ['Effective CLAUDE.md', 'Cost Optimisation', 'Security Hardening', 'Headless Mode', 'Network Security'] },
];
---

<BaseLayout title="Glossary">
  <div class="page">
    <header class="page-header">
      <h1>Glossary</h1>
      <p>Every feature. Full detail. Searchable.</p>
    </header>

    <div class="search-bar">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
      </svg>
      <input type="text" placeholder="Search features by name or keyword..." />
    </div>

    <div class="categories">
      {categories.map((cat) => (
        <details class="category-group" open>
          <summary>
            <span class="category-name">{cat.name}</span>
            <span class="category-count">{cat.count}</span>
          </summary>
          <ul class="category-items">
            {cat.items.map((item) => (
              <li><a href={`/glossary/${item.toLowerCase().replace(/\s+/g, '-')}`}>{item}</a></li>
            ))}
          </ul>
        </details>
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .page {
    max-width: var(--content-width);
    margin: 0 auto;
    padding: 3rem 1.5rem;
  }

  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h1 {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: var(--color-text-muted);
    font-size: 1.05rem;
  }

  .search-bar {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 1rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: var(--color-surface);
    margin-bottom: 2.5rem;
  }

  .search-bar svg {
    color: var(--color-text-muted);
    flex-shrink: 0;
  }

  .search-bar input {
    flex: 1;
    border: none;
    outline: none;
    font-size: 0.95rem;
    font-family: var(--font-sans);
    background: transparent;
    color: var(--color-text);
  }

  .categories {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .category-group {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .category-group summary {
    padding: 1rem 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-weight: 600;
    list-style: none;
  }

  .category-group summary::-webkit-details-marker {
    display: none;
  }

  .category-count {
    background: var(--color-bg);
    color: var(--color-text-muted);
    font-size: 0.75rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    font-weight: 500;
  }

  .category-items {
    list-style: none;
    padding: 0 1.25rem 1rem;
  }

  .category-items li {
    padding: 0.4rem 0;
    border-top: 1px solid var(--color-border);
  }

  .category-items li:first-child {
    border-top: none;
  }

  .category-items a {
    color: var(--color-text);
    font-size: 0.925rem;
  }

  .category-items a:hover {
    color: var(--color-accent);
  }
</style>
