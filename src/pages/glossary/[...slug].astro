---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import CrossLinkCard from '../../components/CrossLinkCard.astro';
import { resolveLinks } from '../../lib/cross-links';

export async function getStaticPaths() {
  const all = await getCollection('glossary');
  return all.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const categoryLabels: Record<string, string> = {
  core: 'Core',
  extensions: 'Extensions',
  integrations: 'Integrations',
  concepts: 'Concepts',
  guides: 'Guides',
};

const categoryColors: Record<string, string> = {
  core: '#e8590c',
  extensions: '#7c3aed',
  integrations: '#2563eb',
  concepts: '#16a34a',
  guides: '#d97706',
};

const categoryLabel = categoryLabels[entry.data.category] ?? entry.data.category;
const categoryColor = categoryColors[entry.data.category] ?? 'var(--color-text-muted)';

// Format last updated from file id (best-effort)
const lastUpdated = new Date().toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

// Resolve learn_links (→ storybook chapters) and use_links (→ cookbooks) to real titles
const resolvedLearnLinks = await resolveLinks(entry.data.learn_links);
const resolvedUseLinks = await resolveLinks(entry.data.use_links);

// Resolve pairs_well_with (glossary slugs) to full paths
const resolvedPairsWellWith = await resolveLinks(
  entry.data.pairs_well_with.map((slug) => `glossary/${slug}`)
);
---

<BaseLayout title={`${entry.data.title} — Glossary`}>
  <div class="glossary-page">
    <!-- Breadcrumb -->
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/glossary">Glossary</a>
      <span aria-hidden="true">›</span>
      <a href={`/glossary?category=${entry.data.category}`}>{categoryLabel}</a>
      <span aria-hidden="true">›</span>
      <span>{entry.data.title}</span>
    </nav>

    <div class="glossary-layout">
      <article class="glossary-main">
        <!-- Header -->
        <header class="glossary-header">
          <div class="glossary-meta">
            <span
              class="category-badge"
              style={`--cat-color: ${categoryColor};`}
            >{categoryLabel}</span>
          </div>
          <h1 class="glossary-title">{entry.data.title}</h1>
        </header>

        <!-- Main content -->
        <div class="prose">
          <Content />
        </div>

        <!-- Pairs well with -->
        {resolvedPairsWellWith.length > 0 && (
          <section class="related-section">
            <h2 class="section-label">Pairs Well With</h2>
            <div class="related-pills">
              {resolvedPairsWellWith.map((link) => (
                <a href={link.href} class="related-pill">
                  {link.title}
                </a>
              ))}
            </div>
          </section>
        )}

        <!-- Learn this -->
        {resolvedLearnLinks.length > 0 && (
          <section class="related-section">
            <h2 class="section-label">Learn This</h2>
            <div class="cross-links-list">
              {resolvedLearnLinks.map((link) => (
                <CrossLinkCard
                  href={link.href}
                  pillar={link.pillar}
                  title={link.title}
                  preview={link.exists ? link.preview : 'Storybook chapter'}
                />
              ))}
            </div>
          </section>
        )}

        <!-- See it in action -->
        {resolvedUseLinks.length > 0 && (
          <section class="related-section">
            <h2 class="section-label">See It in Action</h2>
            <div class="cross-links-list">
              {resolvedUseLinks.map((link) => (
                <CrossLinkCard
                  href={link.href}
                  pillar="cookbook"
                  title={link.title}
                  preview={link.exists ? link.preview : 'Cookbook recipe'}
                />
              ))}
            </div>
          </section>
        )}

        <!-- Last updated -->
        <footer class="glossary-footer">
          <span class="last-updated">Last updated: {lastUpdated}</span>
        </footer>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .glossary-page {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .breadcrumb a {
    color: var(--color-text-muted);
  }

  .breadcrumb a:hover {
    color: var(--color-accent);
  }

  .glossary-layout {
    max-width: var(--content-width);
  }

  .glossary-header {
    margin-bottom: 2rem;
  }

  .glossary-meta {
    margin-bottom: 0.75rem;
  }

  .category-badge {
    display: inline-flex;
    align-items: center;
    font-size: 0.75rem;
    font-weight: 600;
    color: var(--cat-color);
    background: color-mix(in srgb, var(--cat-color) 10%, transparent);
    border: 1px solid color-mix(in srgb, var(--cat-color) 25%, transparent);
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    letter-spacing: 0.02em;
  }

  .glossary-title {
    font-size: 2rem;
    font-weight: 700;
    line-height: 1.2;
    color: var(--color-text);
  }

  /* Prose */
  .prose {
    font-size: 1rem;
    line-height: 1.75;
    margin-bottom: 2.5rem;
  }

  .prose :global(h2) {
    font-size: 1.4rem;
    font-weight: 700;
    margin: 2.5rem 0 1rem;
    color: var(--color-text);
  }

  .prose :global(h3) {
    font-size: 1.15rem;
    font-weight: 600;
    margin: 2rem 0 0.75rem;
    color: var(--color-text);
  }

  .prose :global(p) {
    margin-bottom: 1.25rem;
  }

  .prose :global(ul),
  .prose :global(ol) {
    margin: 0.75rem 0 1.25rem 1.5rem;
  }

  .prose :global(li) {
    margin-bottom: 0.4rem;
  }

  .prose :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .prose :global(blockquote) {
    border-left: 4px solid var(--color-border);
    padding-left: 1rem;
    color: var(--color-text-muted);
    font-style: italic;
    margin: 1.5rem 0;
  }

  /* Related sections */
  .related-section {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--color-border);
  }

  .section-label {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.75rem;
  }

  .related-pills {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .related-pill {
    display: inline-flex;
    align-items: center;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-accent);
    background: var(--color-accent-light);
    border: 1px solid color-mix(in srgb, var(--color-accent) 25%, transparent);
    padding: 0.3rem 0.75rem;
    border-radius: 999px;
    text-decoration: none;
    transition: background 0.15s;
  }

  .related-pill:hover {
    background: color-mix(in srgb, var(--color-accent) 15%, transparent);
    text-decoration: none;
  }

  .cross-links-list {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  /* Footer */
  .glossary-footer {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
  }

  .last-updated {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  /* Code blocks */
  .prose :global(pre) {
    overflow-x: auto;
    max-width: 100%;
    white-space: pre;
  }

  /* Tables scroll on mobile */
  .prose :global(table) {
    display: block;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .glossary-page {
      padding: 1.5rem 1.25rem 3rem;
    }

    .glossary-layout {
      max-width: 100%;
    }

    .glossary-title {
      font-size: 1.5rem;
    }

    .breadcrumb {
      font-size: 0.8rem;
      gap: 0.35rem;
    }

    .related-pills {
      gap: 0.35rem;
    }
  }
</style>
